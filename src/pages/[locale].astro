---
import HomePage from '../components/HomePage.astro';
import { SUPPORTED_MANIFOLD_LOCALES, isSupportedManifoldLocale } from '../i18n/localeRouting';
import type { ManifoldLocale } from '../i18n/manifoldLocale';

export function getStaticPaths() {
  return SUPPORTED_MANIFOLD_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = Astro.params.locale?.toLowerCase() ?? 'en';
const isSupportedLocale = isSupportedManifoldLocale(localeParam);
const locale = isSupportedLocale ? (localeParam as ManifoldLocale) : null;

if (!isSupportedLocale || !locale) {
  return Astro.redirect('/en/');
}
---

<HomePage locale={locale} />
